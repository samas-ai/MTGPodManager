# Copy to .env.local and fill from your Supabase project (Settings → API).
# The anon key + RLS is the ONLY thing the browser touches.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER-ONLY. Never expose to the browser bundle. Used by import/admin paths (later phases).
SUPABASE_SERVICE_ROLE_KEY=

# Scryfall etiquette (F3). Descriptive User-Agent with contact.
SCRYFALL_USER_AGENT="MTGPodManager/0.1 (contact@example.com)"

# Public site origin (used for metadata canonical/OG + robots/sitemap).
# In Vercel set this to your production URL, e.g. https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Live-match join-status transport (F4): "realtime" (Postgres Changes, default)
# or "polling" (re-query every 3s) — the free-tier-resilient fallback.
NEXT_PUBLIC_REALTIME_TRANSPORT="realtime"
